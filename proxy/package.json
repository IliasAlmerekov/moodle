{
  "name": "moodle-proxy",
  "version": "0.1.0",
  "description": "AI-powered learning assistant for Moodle LMS — Clean Architecture, Fastify, Ollama, SQLite",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "src/frameworks/webserver/server.js",
  "scripts": {
    "start": "node src/frameworks/webserver/server.js",
    "dev": "node --watch src/frameworks/webserver/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix"
  },
  "dependencies": {
    "@fastify/cors": "^8.4.0",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/static": "^6.12.0",
    "better-sqlite3": "^12.10.0",
    "fastify": "4.28.1",
    "p-queue": "^9.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^10.4.0",
    "eslint-plugin-n": "^18.0.1",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "vitest": "^4.1.7"
  },
  "overrides": {
    "fast-uri": "3.1.2"
  }
}
