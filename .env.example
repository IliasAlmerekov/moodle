# ==============================================================================
# MariaDB — Moodle database
# ==============================================================================
MARIADB_USER=bn_moodle
MARIADB_PASSWORD=<database_password>
MARIADB_DATABASE=bitnami_moodle
MARIADB_ROOT_PASSWORD=<database_root_password>

# ==============================================================================
# Moodle — administrator credentials
# ==============================================================================
MOODLE_USERNAME=admin
MOODLE_PASSWORD=<moodle_admin_password>

# ==============================================================================
# Network — service ports
# ==============================================================================
MOODLE_HTTP_PORT=8080
PROXY_PORT=3000

# ==============================================================================
# Node.js — environment and proxy server port
# ==============================================================================
NODE_ENV=production
PORT=3000

# Log level: error | warn | info | debug
LOG_LEVEL=info

# ==============================================================================
# Moodle REST API — required variables
# ==============================================================================

# Internal Moodle URL (used by proxy for API requests)
MOODLE_URL=http://moodle:8080

# Moodle webservice token (Administration → Plugins → Web services → Tokens)
MOODLE_TOKEN=<moodle_webservice_token>

# Public Moodle URL (used in course links shown to users)
PUBLIC_MOODLE_URL=https://www.itech-bs14.de

# ==============================================================================
# Ollama — local LLM server (required variables)
# ==============================================================================

# Ollama URL (inside Docker Compose — http://ollama:11434)
OLLAMA_URL=http://ollama:11434

# Ollama model (must be pulled first: ollama pull <model>)
OLLAMA_MODEL=llama3.2:3b

# Maximum number of parallel requests to Ollama
OLLAMA_CONCURRENCY=2

# Ollama response timeout in milliseconds (30 seconds)
OLLAMA_TIMEOUT_MS=30000

# ==============================================================================
# CORS — allowed request origins
# ==============================================================================

# Comma-separated list of allowed origins. Empty value disables CORS.
CORS_ORIGIN=http://localhost:8080,https://www.itech-bs14.de

# ==============================================================================
# Rate limiting — request rate limits
# ==============================================================================

# Maximum number of requests per time window (per IP)
RATE_LIMIT_MAX=20

# Time window for rate limiting (formats: "1 minute", "30 seconds", "1 hour")
RATE_LIMIT_WINDOW=1 minute

# ==============================================================================
# Cache — cached data TTL (in milliseconds)
# ==============================================================================

# Moodle course structure cache TTL (300 000 ms = 5 minutes)
CACHE_TTL_COURSES=300000

# Moodle user data cache TTL (60 000 ms = 1 minute)
CACHE_TTL_USERS=60000

# ==============================================================================
# Chat — message limits and history storage
# ==============================================================================

# Maximum length of a single user message (in characters)
MAX_MESSAGE_LENGTH=500

# Maximum number of history messages passed to LLM context
MAX_HISTORY_MESSAGES=12

# Path to SQLite file for chat history storage
CHAT_DB_PATH=../data/chat.db
