# ==============================================================================
# MariaDB — база данных Moodle
# ==============================================================================
MARIADB_USER=bn_moodle
MARIADB_PASSWORD=<пароль_базы_данных>
MARIADB_DATABASE=bitnami_moodle
MARIADB_ROOT_PASSWORD=<root_пароль_базы_данных>

# ==============================================================================
# Moodle — учётные данные администратора
# ==============================================================================
MOODLE_USERNAME=admin
MOODLE_PASSWORD=<пароль_администратора_moodle>

# ==============================================================================
# Сеть — порты сервисов
# ==============================================================================
MOODLE_HTTP_PORT=8080
PROXY_PORT=3000

# ==============================================================================
# Node.js — окружение и порт proxy-сервера
# ==============================================================================
NODE_ENV=production
PORT=3000

# Уровень логирования: error | warn | info | debug
LOG_LEVEL=info

# ==============================================================================
# Moodle REST API — обязательные переменные
# ==============================================================================

# Внутренний URL Moodle (используется proxy для API-запросов)
MOODLE_URL=http://moodle:8080

# Токен веб-сервиса Moodle (Администрирование → Плагины → Веб-сервисы → Токены)
MOODLE_TOKEN=<токен_веб_сервиса_moodle>

# Публичный URL Moodle (используется в ссылках на курсы для пользователей)
PUBLIC_MOODLE_URL=https://www.itech-bs14.de

# ==============================================================================
# Ollama — локальный LLM-сервер (обязательные переменные)
# ==============================================================================

# URL Ollama (внутри Docker Compose — http://ollama:11434)
OLLAMA_URL=http://ollama:11434

# Модель Ollama (должна быть загружена: ollama pull <model>)
OLLAMA_MODEL=llama3.2:3b

# Максимальное количество параллельных запросов к Ollama
OLLAMA_CONCURRENCY=2

# Таймаут ожидания ответа от Ollama в миллисекундах (30 секунд)
OLLAMA_TIMEOUT_MS=30000

# ==============================================================================
# CORS — разрешённые источники запросов
# ==============================================================================

# Список допустимых источников через запятую. Пустое значение — CORS отключён.
CORS_ORIGIN=http://localhost:8080,https://www.itech-bs14.de

# ==============================================================================
# Rate limiting — ограничение количества запросов
# ==============================================================================

# Максимальное количество запросов за окно времени (на один IP)
RATE_LIMIT_MAX=20

# Окно времени для rate limiting (форматы: "1 minute", "30 seconds", "1 hour")
RATE_LIMIT_WINDOW=1 minute

# ==============================================================================
# Кеш — время жизни кешированных данных (в миллисекундах)
# ==============================================================================

# TTL кеша структуры курсов Moodle (300 000 мс = 5 минут)
CACHE_TTL_COURSES=300000

# TTL кеша данных пользователей Moodle (60 000 мс = 1 минута)
CACHE_TTL_USERS=60000

# ==============================================================================
# Чат — лимиты сообщений и хранилище истории
# ==============================================================================

# Максимальная длина одного сообщения от пользователя (в символах)
MAX_MESSAGE_LENGTH=500

# Максимальное количество сообщений истории, передаваемых в контекст LLM
MAX_HISTORY_MESSAGES=12

# Путь к файлу SQLite для хранения истории чата
CHAT_DB_PATH=../data/chat.db
